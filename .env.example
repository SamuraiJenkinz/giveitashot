# Azure AD App Registration Configuration
# Copy this file to .env and fill in your values

# Your Azure AD Tenant ID (Directory ID)
AZURE_TENANT_ID=your-tenant-id-here

# The Application (Client) ID from your Azure AD app registration
AZURE_CLIENT_ID=your-client-id-here

# The Client Secret from your Azure AD app registration
AZURE_CLIENT_SECRET=your-client-secret-here

# Your email address (used for sending the summary email)
USER_EMAIL=kevin.j.taylor@mmc.com

# Shared mailbox to read emails from
SHARED_MAILBOX=messagingai@marsh.com

# ============================================
# Summary Email Recipients
# ============================================
# Option 1: Single recipient (legacy, simple)
SUMMARY_RECIPIENT=kevin.j.taylor@mmc.com

# Option 2: Multiple recipients with TO/CC/BCC support
# These take precedence over SUMMARY_RECIPIENT if SUMMARY_TO is set
# Use comma-separated values for multiple addresses

# TO recipients (required if using this option)
# SUMMARY_TO=manager@company.com,team-lead@company.com

# CC recipients (optional)
# SUMMARY_CC=team@company.com,stakeholder@company.com

# BCC recipients (optional) - useful for archiving
# SUMMARY_BCC=archive@company.com

# EWS Server (usually outlook.office365.com for M365)
EWS_SERVER=outlook.office365.com

# ============================================
# Azure OpenAI Configuration (for AI summaries)
# ============================================

# Your Azure OpenAI endpoint URL
CHATGPT_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-openai-api-key-here

# API version (usually 2023-05-15)
API_VERSION=2023-05-15

# Enable/disable LLM summarization (true/false)
# Set to false to use basic text extraction instead of AI summaries
USE_LLM_SUMMARY=true

# Optional: Set to 'true' for verbose logging
DEBUG=false
